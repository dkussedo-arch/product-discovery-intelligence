# Required — Claude synthesis / chat / analysis
ANTHROPIC_API_KEY=

# Optional — Helicone observability (when set, requests route via Helicone)
HELICONE_API_KEY=

# Optional — protect cross-origin API access (Authorization: Bearer <secret> or x-api-key)
# Same-origin browser calls from this Next.js app are allowed without the header.
PDI_API_SECRET=

# Optional — default API base for external clients / AI Studio
NEXT_PUBLIC_PDI_API_URL=

# Optional — extra CORS origins (comma-separated) for AI Studio / custom frontends
ALLOWED_CORS_ORIGINS=

# Optional — Supabase document upload
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — PostHog analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
